# ---------------------------------------------------------------------------
# Aitek Billing — Environment Variables
# Copy this file to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) -------------------------------------------------
# Local example: postgresql://postgres:postgres@localhost:5432/aitek_billing?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/aitek_billing?schema=public"

# --- NextAuth --------------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# From `stripe listen` (dev) or the Stripe dashboard webhook (prod)
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# --- Microsoft Graph (Outlook shared inbox) --------------------------------
# Created via an Azure AD App Registration — see README for full steps.
MICROSOFT_CLIENT_ID="00000000-0000-0000-0000-000000000000"
MICROSOFT_TENANT_ID="00000000-0000-0000-0000-000000000000"
MICROSOFT_CLIENT_SECRET="your-client-secret-value"
# The shared mailbox emails are sent FROM, e.g. billing@aitek-solutions.com
SHARED_MAILBOX_ADDRESS="billing@aitek-solutions.com"

# --- Company / App ---------------------------------------------------------
COMPANY_NAME="Aitek Solutions"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Cron job protection ---------------------------------------------------
# Shared secret required to invoke /api/cron/* endpoints from an external
# scheduler (the in-process node-cron worker reads it automatically).
CRON_SECRET="replace-with-a-long-random-string"

# --- Initial admin seed (used by `npm run db:seed`) ------------------------
SEED_ADMIN_EMAIL="admin@aitek-solutions.com"
SEED_ADMIN_PASSWORD="ChangeMe!123"
SEED_ADMIN_NAME="Aitek Admin"
