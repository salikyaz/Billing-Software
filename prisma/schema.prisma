// Aitek Billing — Prisma schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum NotificationType {
  INVOICE_SENT
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  REMINDER_SENT
}

enum EmailStatus {
  SUCCESS
  FAILED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // bcrypt hash
  name      String
  createdAt DateTime @default(now())

  // Password reset (forgot-password flow)
  resetTokenHash   String? // sha256 hash of the emailed token
  resetTokenExpiry DateTime?

  // Email 2FA login challenge
  twoFactorCodeHash    String? // sha256 hash of the emailed 6-digit code
  twoFactorCodeExpiry  DateTime?
  twoFactorAttempts    Int       @default(0) // failed code guesses for the active code
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  address   String?
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices        Invoice[]
  clientServices  ClientService[]

  @@index([email])
}

model Service {
  id           String   @id @default(cuid())
  name         String
  description  String?
  defaultPrice Decimal  @db.Decimal(12, 2)
  unit         String   @default("monthly") // e.g. "monthly", "per hour", "one-time"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoiceItems   InvoiceItem[]
  clientServices ClientService[]
}

// Recurring services assigned to a client, used by the monthly auto-billing job.
model ClientService {
  id          String   @id @default(cuid())
  clientId    String
  serviceId   String
  quantity    Int      @default(1)
  customPrice Decimal? @db.Decimal(12, 2) // overrides Service.defaultPrice when set
  createdAt   DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([clientId, serviceId])
  @@index([clientId])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique // e.g. INV-2024-0001
  clientId      String
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(12, 2)
  taxRate       Decimal       @default(0) @db.Decimal(5, 2) // percentage, e.g. 10.00
  tax           Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  currency      String        @default("USD")
  notes         String?
  dueDate       DateTime
  sentAt        DateTime?
  paidAt        DateTime?
  reminderSentAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  stripePaymentLinkId   String?
  stripePaymentLinkUrl  String?
  stripePaymentIntentId String?

  client        Client         @relation(fields: [clientId], references: [id])
  items         InvoiceItem[]
  notifications Notification[]
  emailLogs     EmailLog[]

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  serviceId   String?
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  message   String
  invoiceId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([isRead])
  @@index([createdAt])
}

model EmailLog {
  id             String      @id @default(cuid())
  invoiceId      String?
  recipientEmail String
  subject        String
  status         EmailStatus
  errorMessage   String?
  sentAt         DateTime    @default(now())

  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

// Singleton row (id = "singleton") holding configurable app settings.
model Settings {
  id      String @id @default("singleton")

  // Company info
  companyName    String  @default("Aitek Solutions")
  companyEmail   String?
  companyAddress String?
  companyPhone   String?
  logoUrl        String?

  // Billing config
  taxRate          Decimal @default(0) @db.Decimal(5, 2) // percentage
  defaultCurrency  String  @default("USD")
  billingDay       Int     @default(1) // day of month for auto-billing
  reminderAfterDays Int    @default(7) // days overdue before a reminder is sent
  invoiceNumberPrefix String @default("INV")

  // Microsoft Graph (Outlook shared inbox). NON-SECRET config only — the
  // client SECRET lives in the MICROSOFT_CLIENT_SECRET env var, never the DB.
  msClientId    String?
  msTenantId    String?
  sharedMailbox String?

  // Stripe. The secret key lives in the STRIPE_SECRET_KEY env var, never the
  // DB. The publishable key is public by design.
  stripePublishableKey String?

  // Security
  twoFactorEnabled Boolean @default(false) // require email 2FA on admin login

  updatedAt DateTime @updatedAt @default(now())
}
